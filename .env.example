# ╔══════════════════════════════════════════════════════════════════════╗
# ║           Threat Intelligence Pipeline — Environment Config         ║
# ║  Copy this file to .env and fill in your values.                   ║
# ║  Lines starting with # are comments.                               ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Kafka ───────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_BOOTSTRAP_SERVERS_EXTERNAL=localhost:9092
KAFKA_TOPIC_RAW=iocs.raw
KAFKA_TOPIC_ENRICHED=iocs.enriched
KAFKA_TOPIC_ALERTS=alerts.critical
KAFKA_GROUP_ID=threat-intel-group

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=threatintel
POSTGRES_USER=threatintel
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://threatintel:changeme_in_production@postgres:5432/threatintel

# ── FastAPI ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_DEBUG=false

# ── Authentication ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
NEXTAUTH_SECRET=change_this_nextauth_secret_too
NEXTAUTH_URL=http://localhost:3000

# ── Default Admin User ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@threatintel.local
ADMIN_PASSWORD=changeme

# ── Apache Spark ─────────────────────────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_APP_NAME=ThreatIntelPipeline
SPARK_CHECKPOINT_DIR=/tmp/spark-checkpoints
SPARK_LOG_LEVEL=WARN

# ── OSINT API Keys ───────────────────────────────────────────────────────
# Leave empty to use mock data (fully functional without API keys)

# AbuseIPDB: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# VirusTotal: https://www.virustotal.com/gui/sign-in
VIRUSTOTAL_API_KEY=

# AlienVault OTX: https://otx.alienvault.com/
OTX_API_KEY=

# ── Mock Feed (development) ───────────────────────────────────────────────
MOCK_FEED_ENABLED=true
MOCK_FEED_INTERVAL_SECONDS=3
MOCK_FEED_BATCH_SIZE=5

# ── Enrichment ────────────────────────────────────────────────────────────
GEO_DB_PATH=/app/data/GeoLite2-City.mmdb
ENRICHMENT_TIMEOUT_SECONDS=5
